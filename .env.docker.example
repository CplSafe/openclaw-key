# ====== OpenClaw Docker 部署配置 ======

# 数据库密码（请修改为强密码）
DB_PASSWORD=openclaw_secret_2026

# 对外端口（浏览器访问的端口）
APP_PORT=3000

# 公网访问地址（改成你的服务器域名或IP）
# 示例: http://your-domain.com:3000 或 https://your-domain.com
API_BASE_URL=http://localhost:3000

# 加密密钥（运行: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))" 生成）
ENCRYPTION_KEY=

# JWT 密钥（运行: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))" 生成）
JWT_SECRET=
